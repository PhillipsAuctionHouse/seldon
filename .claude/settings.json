{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$CLAUDE_PROJECT_DIR/.agents/skills/seldon/SKILL.md\" \"$CLAUDE_PROJECT_DIR/.agents/skills/vercel-composition-patterns/SKILL.md\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-pr-template.sh\"",
            "if": "Bash(gh pr *)"
          }
        ]
      }
    ]
  }
}
